{
  "name": "@secuclaw/core",
  "version": "1.0.0",
  "description": "SecuClaw Core Engine - AI-powered security operations platform core components",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./agent": "./src/agent/index.ts",
    "./skills": "./src/skills/index.ts",
    "./tools": "./src/tools/index.ts",
    "./memory": "./src/memory/index.ts",
    "./session": "./src/session/index.ts",
    "./gateway": "./src/gateway/index.ts",
    "./scheduler": "./src/scheduler/index.ts",
    "./ontology": "./src/ontology/index.ts",
    "./knowledge": "./src/knowledge/index.ts",
    "./learning": "./src/learning/index.ts",
    "./config": "./src/config/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target=bun",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.29.0",
    "gray-matter": "^4.0.0",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.20.0",
    "bun-types": "^1.0.0",
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0"
  }
}
