            { id: "gdpr", name: "GDPR", version: "2018", totalControls: 99, compliantControls: 85, partiallyCompliant: 10, nonCompliant: 4, lastAssessment: "2024-02-01", nextAssessment: "2024-08-01", status: "partially_compliant" },
