export interface GatewayOptions {
  port: number;
  dataDir: string;
  configManager: ConfigManager;
  skillLoader: SkillLoader;
  host?: string;
  webDistDir?: string;
}

export interface GatewayState {
  running: boolean;
  port: number;
  host: string;
  connections: number;
  startTime: Date | null;
}

