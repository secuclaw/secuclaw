{
  "name": "@secuclaw/cli",
  "version": "1.0.0",
  "description": "SecuClaw CLI - Command line interface for SecuClaw security platform",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "secuclaw": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target=bun",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "@secuclaw/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.0.0"
  }
}
